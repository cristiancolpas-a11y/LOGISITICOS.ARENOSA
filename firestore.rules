rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }
    
    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidPeopleUser(data) {
      // Allow identification or uniqueCode for backward compatibility
      return hasRequiredFields(['name', 'role', 'createdAt']) &&
             data.role in ['padrino', 'apadrinado', 'admin'] &&
             data.createdAt is string;
    }
    
    function isValidMentorshipPlan(data) {
      return hasOnlyAllowedFields(['padrinoId', 'apadrinadoId', 'padrinoName', 'apadrinadoName', 'startDate', 'endDate', 'status', 'progress', 'lastActivityAt', 'createdAt', 'planId', 'pilar', 'matriz']) &&
             (!('padrinoId' in data) || isValidString(data.padrinoId, 1, 50)) &&
             (!('apadrinadoId' in data) || isValidString(data.apadrinadoId, 1, 50)) &&
             (!('startDate' in data) || data.startDate is string) &&
             (!('endDate' in data) || data.endDate is string) &&
             (!('status' in data) || data.status in ['Activo', 'En proceso', 'Finalizado']) &&
             (!('progress' in data) || (data.progress is number && data.progress >= 0 && data.progress <= 100)) &&
             (!('lastActivityAt' in data) || data.lastActivityAt is string) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('planId' in data) || data.planId is string) &&
             (!('pilar' in data) || data.pilar is string) &&
             (!('matriz' in data) || data.matriz is string);
    }

    function isValidMentorshipTask(data) {
      return hasOnlyAllowedFields(['planId', 'sheetTaskId', 'description', 'pilar', 'matriz', 'subnivel', 'requiresEvidence', 'evidenceUrl', 'evidenceName', 'evidenceType', 'uploadedAt', 'evidenceDate', 'isCompleted', 'completedAt', 'createdAt', 'updatedAt', 'isFuncional', 'id', 'padrinoName', 'apadrinadoName']) &&
             (!('planId' in data) || isValidString(data.planId, 1, 100)) &&
             (!('sheetTaskId' in data) || isValidString(data.sheetTaskId, 1, 1000)) &&
             (!('description' in data) || isValidString(data.description, 1, 2000)) &&
             (!('isCompleted' in data) || data.isCompleted is bool) &&
             (!('pilar' in data) || data.pilar is string) &&
             (!('matriz' in data) || data.matriz is string) &&
             (!('subnivel' in data) || data.subnivel is string) &&
             (!('requiresEvidence' in data) || data.requiresEvidence is bool) &&
             (!('evidenceUrl' in data) || data.evidenceUrl is string) &&
             (!('evidenceName' in data) || data.evidenceName is string) &&
             (!('evidenceType' in data) || data.evidenceType is string) &&
             (!('uploadedAt' in data) || data.uploadedAt is string) &&
             (!('updatedAt' in data) || data.updatedAt is string) &&
             (!('evidenceDate' in data) || data.evidenceDate is string) &&
             (!('completedAt' in data) || data.completedAt == null || data.completedAt is string) &&
             (!('isFuncional' in data) || data.isFuncional is bool) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('id' in data) || data.id is string) &&
             (!('padrinoName' in data) || data.padrinoName is string) &&
             (!('apadrinadoName' in data) || data.apadrinadoName is string);
    }
    
    function isValidMentorshipMessage(data) {
      return hasOnlyAllowedFields(['planId', 'senderId', 'text', 'attachments', 'readBy', 'createdAt']) &&
             hasRequiredFields(['planId', 'senderId', 'text', 'attachments', 'readBy', 'createdAt']) &&
             isValidString(data.planId, 1, 50) &&
             isValidString(data.senderId, 1, 50) &&
             data.text is string && data.text.size() <= 2000 &&
             data.attachments is list && data.attachments.size() <= 5 &&
             data.readBy is list && data.readBy.size() <= 10 &&
             data.createdAt is string;
    }
    
    function isValidMentorshipObservation(data) {
      return hasOnlyAllowedFields(['planId', 'authorId', 'text', 'createdAt']) &&
             hasRequiredFields(['planId', 'authorId', 'text', 'createdAt']) &&
             isValidString(data.planId, 1, 50) &&
             isValidString(data.authorId, 1, 50) &&
             isValidString(data.text, 1, 2000) &&
             data.createdAt is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    // For prototype purposes, we allow authenticated users (anonymous) to read/write.
    // In a production app, we would restrict based on the user's role and ID.
    
    match /people_users/{userId} {
      // Allow reading a specific user document if you know its ID (the unique code)
      allow get: if isAuthenticated();
      // Allow listing users (needed for admins or to select a padrino/apadrinado)
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPeopleUser(request.resource.data);
      allow update: if isAuthenticated() && isValidPeopleUser(request.resource.data);
      allow delete: if false;
    }
    
    match /mentorship_plans/{planId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMentorshipPlan(request.resource.data) && hasRequiredFields(['padrinoId', 'apadrinadoId', 'status', 'progress', 'createdAt']);
      allow update: if isAuthenticated() && isValidMentorshipPlan(request.resource.data);
      allow delete: if false;
    }
    
    match /mentorship_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMentorshipTask(request.resource.data) && hasRequiredFields(['planId', 'description', 'createdAt']);
      allow update: if isAuthenticated() && isValidMentorshipTask(request.resource.data);
      allow delete: if isAuthenticated(); // Allow deleting tasks
    }
    
    match /mentorship_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMentorshipMessage(request.resource.data);
      allow update: if isAuthenticated() && isValidMentorshipMessage(request.resource.data);
      allow delete: if isAuthenticated();
    }
    
    match /mentorship_observations/{observationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMentorshipObservation(request.resource.data);
      allow update: if isAuthenticated() && isValidMentorshipObservation(request.resource.data);
      allow delete: if false;
    }
  }
}
